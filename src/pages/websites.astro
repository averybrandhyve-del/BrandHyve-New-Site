---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Web Design & Performance | BrandHyve Custom Sites" description="Get high-performance custom-coded websites built for speed, conversion, and ranking. Explore our portfolio of client case projects." schemaType="software">
  <!-- Global Decorative Background Glows -->
  <div class="glow-glow" style="top: 20%; left: 10%;"></div>
  <div class="glow-glow" style="top: 65%; right: 8%; width: 250px; height: 250px; background: #888888; animation-delay: -3s;"></div>

  <!-- Hero Section -->
  <section class="section-padding websites-hero">
    <div class="section-header">
      <span class="caption">Web Design & Performance</span>
      <h1 class="display-xl">Custom Code. Speed. Maximum Conversion.</h1>
      <p class="body-lg">Say goodbye to slow, bloated website builders. We engineer lightweight, custom-coded web architectures that load in milliseconds, rank higher in local search, and convert visitors into active clients.</p>
    </div>

    <!-- Performance Stats Section -->
    <div class="performance-stats-wrapper">
      <div class="card spotlight-card col-12">
        <div class="spotlight-card-content performance-grid">
          <div class="perf-metric">
            <span class="display-xl perf-number">100</span>
            <span class="perf-label">Google Mobile PageSpeed</span>
          </div>
          <div class="perf-text">
            <h3>Why Custom Coded Websites Win</h3>
            <p class="body-lg" style="margin-top: 10px;">
              Search engine ranking algorithms penalize slow-loading, bloated sites. We build our client sites with optimized HTML, lightweight CSS stylesheets, and clean scripts. This guarantees near-instant load times, flawless responsiveness, and solid mobile user experiences.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Showcase Section -->
  <section class="section-padding portfolio-section" style="padding-top: 0;">
    <div class="section-header">
      <span class="caption">Our Work</span>
      <h2 class="display-lg">Featured Client Deployments</h2>
      <p class="body-lg">Explore custom-coded platforms built for performance, lead capture, and automated feedback syncing.</p>
    </div>

    <div class="card-grid">
      <!-- Project 1: Comfortable Air -->
      <div class="card spotlight-card col-6">
        <div class="spotlight-card-content project-card">
          <div class="project-header">
            <span class="project-domain">HVAC Services</span>
            <span class="project-speed">⚡ 99/100 Speed</span>
          </div>
          <h3>Comfortable Air</h3>
          <p>
            Custom service-area layout site designed for local HVAC bookings. Features review request triggers immediately following scheduled service visits and dispatch updates.
          </p>
          <div class="project-footer">
            <span class="footer-tag">Astro</span>
            <span class="footer-tag">Custom CSS</span>
            <span class="footer-tag">Review Sync</span>
          </div>
        </div>
      </div>

      <!-- Project 2: Austin Dental Hub -->
      <div class="card spotlight-card col-6">
        <div class="spotlight-card-content project-card">
          <div class="project-header">
            <span class="project-domain">Healthcare</span>
            <span class="project-speed">⚡ 100/100 Speed</span>
          </div>
          <h3>Austin Dental Hub</h3>
          <p>
            Appointment-optimized landing architecture. Connects patient scheduling modules directly to customer feedback systems for high rating acquisition.
          </p>
          <div class="project-footer">
            <span class="footer-tag">Astro</span>
            <span class="footer-tag">Schedule Engine</span>
            <span class="footer-tag">Local Schema</span>
          </div>
        </div>
      </div>

      <!-- Project 3: Elite Law Group -->
      <div class="card spotlight-card col-6">
        <div class="spotlight-card-content project-card">
          <div class="project-header">
            <span class="project-domain">Legal Services</span>
            <span class="project-speed">⚡ 98/100 Speed</span>
          </div>
          <h3>Elite Law Group</h3>
          <p>
            High-contrast visual design layout for corporate consultation intake. Built with access compliance structures and real-time positive feedback highlight feeds.
          </p>
          <div class="project-footer">
            <span class="footer-tag">Performance HTML</span>
            <span class="footer-tag">Intake Forms</span>
            <span class="footer-tag">Secure SSL</span>
          </div>
        </div>
      </div>

      <!-- Project 4: The Green Oasis -->
      <div class="card spotlight-card col-6">
        <div class="spotlight-card-content project-card">
          <div class="project-header">
            <span class="project-domain">Architecture</span>
            <span class="project-speed">⚡ 100/100 Speed</span>
          </div>
          <h3>The Green Oasis</h3>
          <p>
            Landscape architecture portfolio showcasing high-resolution image galleries using optimized lazy loading to protect core web vitals.
          </p>
          <div class="project-footer">
            <span class="footer-tag">Image Optimization</span>
            <span class="footer-tag">Portfolios</span>
            <span class="footer-tag">Astro SSG</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky CTA Banner -->
  <section class="section-padding cta-banner-section">
    <div class="atmosphere-card-grey cta-banner border-beam-card">
      <div class="border-beam-content" style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 40px; flex-wrap: wrap;">
        <div class="cta-left">
          <h2 class="display-md">Ready for a High Performance Upgrade?</h2>
          <p class="body-lg" style="margin-top: 10px;">
            Let us build a lightning-fast web infrastructure that converts visitors and dominates search results.
          </p>
        </div>
        <div class="cta-right">
          <a href="/contact" class="btn-primary" style="padding: 16px 36px;">Talk to our team</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import '../scripts/main.js';
</script>

<style>
  /* Local Component Styling */
  .websites-hero {
    padding-top: 150px;
  }

  .section-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 60px;
  }

  .section-header .caption {
    color: var(--accent-yellow);
    margin-bottom: 12px;
    display: block;
  }

  .section-header h1 {
    margin-bottom: 20px;
  }

  .performance-stats-wrapper {
    margin-bottom: 40px;
  }

  .performance-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 40px;
    align-items: center;
    padding: 20px;
  }

  @media (max-width: 810px) {
    .performance-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      text-align: center;
    }
  }

  .perf-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--hairline);
    padding-right: 40px;
  }

  @media (max-width: 810px) {
    .perf-metric {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid var(--hairline);
      padding-bottom: 20px;
    }
  }

  .perf-number {
    color: var(--accent-yellow) !important;
    font-weight: 700;
    line-height: 1;
  }

  .perf-label {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-top: 10px;
  }

  .perf-text h3 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 15px;
  }

  /* Portfolio grid cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
  }

  .card-grid .col-6 {
    grid-column: span 6;
  }

  .card-grid .col-12 {
    grid-column: span 12;
  }

  @media (max-width: 810px) {
    .card-grid .col-6 {
      grid-column: span 12;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--hairline-soft);
    padding-bottom: 15px;
    margin-bottom: 5px;
  }

  .project-domain {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
  }

  .project-speed {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent-yellow);
    background-color: rgba(255, 219, 21, 0.1);
    padding: 3px 8px;
    border-radius: var(--rounded-xs);
  }

  .project-card h3 {
    font-size: 22px;
    font-weight: 600;
  }

  .project-card p {
    color: var(--ink-muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .project-footer {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 15px;
    border-top: 1px solid var(--hairline-soft);
    padding-top: 15px;
  }

  .footer-tag {
    font-size: 11px;
    font-weight: 500;
    background-color: var(--surface-2);
    border: 1px solid var(--hairline);
    color: var(--ink);
    padding: 4px 10px;
    border-radius: var(--rounded-sm);
  }
</style>
