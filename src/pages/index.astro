---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrandHyve | Automated Google Reviews & Local SEO Autopilot" description="Grow your online reputation with automated Google reviews, compliant customer feedback flows, and AI responses. Push your Google Map Pack ranking to the top automatically." schemaType="software">
  <!-- Global Decorative Background Glows -->
  <div class="glow-glow" style="top: 15%; left: 10%;"></div>
  <div class="glow-glow" style="top: 55%; right: 5%; width: 250px; height: 250px; background: #888888; animation-delay: -3s;"></div>
  <div class="glow-glow" style="top: 80%; left: 8%;"></div>

  <!-- Hero Section -->
  <section class="section-padding hero-section">
    <div class="hero-content">
      <div class="badge">
        <span class="badge-dot"></span> Powered by Google Review Automation
      </div>
      <h1 class="display-xxl">
        Automate Google Reviews.<br/>
        Dominate Local Maps. <span class="highlight-text">Grow Business.</span>
      </h1>
      <p class="subhead hero-subhead">
        BrandHyve automates reputation management and maps rank optimization for local businesses. Set up customer invite outreach campaigns that generate positive reviews on autopilot.
      </p>
      <div class="hero-actions">
        <a href="/reviews#pricing" class="btn-primary">Join the Hyve</a>
        <a href="/reviews" class="btn-secondary">See How It Works</a>
      </div>
    </div>

    <!-- Live Review Request Dashboard Mockup -->
    <div class="dashboard-mockup-wrapper">
      <div class="glass-card dashboard-card">
        <div class="dashboard-header">
          <div class="window-controls">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="dashboard-title">BrandHyve Engine Dashboard</div>
          <div class="dashboard-badge">Live Sandbox</div>
        </div>

        <div class="dashboard-body">
          <!-- Main Stats Grid -->
          <div class="dashboard-stats">
            <div class="stat-box">
              <span class="stat-label">Google Rating</span>
              <span class="stat-value">4.9 <span class="star-icon">★</span></span>
              <span class="stat-trend positive">↑ 0.4 this month</span>
            </div>
            <div class="stat-box">
              <span class="stat-label">Total Reviews</span>
              <span id="mock-stat-reviews" class="stat-value">142</span>
              <span class="stat-trend positive">+18 new</span>
            </div>
            <div class="stat-box">
              <span class="stat-label">Response Rate</span>
              <span id="mock-stat-response" class="stat-value">83.5%</span>
              <span class="stat-trend">Automated responses active</span>
            </div>
          </div>

          <div class="dashboard-content-split">
            <!-- Invite Form (Left) -->
            <div class="dashboard-pane form-pane">
              <h3>Send Review Invite</h3>
              <p class="pane-desc">Simulate sending an automated review request to your customer.</p>
              <form id="mock-invite-form" class="mock-form">
                <div class="form-group">
                  <label for="mock-cust-name">Customer Name</label>
                  <input type="text" id="mock-cust-name" placeholder="John Doe" required />
                </div>
                <div class="form-group">
                  <label for="mock-cust-contact">Email or Phone Number</label>
                  <input type="text" id="mock-cust-contact" placeholder="john@example.com" required />
                </div>
                <div class="form-group-row">
                  <div class="form-group-half">
                    <label for="mock-channel">Channel</label>
                    <select id="mock-channel">
                      <option value="sms">SMS Text</option>
                      <option value="email">Email</option>
                    </select>
                  </div>
                  <div class="form-group-half btn-group">
                    <button type="submit" class="btn-primary mock-submit-btn">Send Invite</button>
                  </div>
                </div>
              </form>
            </div>

            <!-- Sent Invites Table (Right) -->
            <div class="dashboard-pane table-pane">
              <h3>Recent Requests</h3>
              <div class="dashboard-table-header">
                <span>Customer</span>
                <span>Contact</span>
                <span>Channel</span>
                <span>Status</span>
              </div>
              <div id="mock-invites-list" class="dashboard-table-body">
                <div class="dashboard-row">
                  <span class="cust-name">Sarah Jenkins</span>
                  <span class="cust-contact">sarah.j@gmail.com</span>
                  <span class="cust-channel channel-email">EMAIL</span>
                  <span class="cust-status status-completed">Completed</span>
                </div>
                <div class="dashboard-row">
                  <span class="cust-name">Michael Chang</span>
                  <span class="cust-contact">+1 (512) 555-0192</span>
                  <span class="cust-channel channel-sms">SMS</span>
                  <span class="cust-status status-completed">Completed</span>
                </div>
                <div class="dashboard-row">
                  <span class="cust-name">David Ross</span>
                  <span class="cust-contact">dross@yahoo.com</span>
                  <span class="cust-channel channel-email">EMAIL</span>
                  <span class="cust-status status-completed">Completed</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Simulated Toast Notification -->
      <div id="mock-toast" class="toast-notify">Sending review request...</div>
    </div>
  </section>

  <!-- Scroll-Triggered Stats Counters -->
  <section class="section-padding stats-section" style="padding-top: 0;">
    <div class="atmosphere-card-grey border-beam-card">
      <div class="border-beam-content" style="width: 100%;">
        <h2 class="display-md" style="text-align: center; margin-bottom: 50px; color: var(--ink);">Why Google Reviews Matter</h2>
        <div class="stats-counters-grid">
          <div class="counter-item">
            <span class="stat-counter display-xl" data-limit="92" data-suffix="%">0%</span>
            <span class="counter-label">Of consumers read online reviews before choosing local businesses.</span>
          </div>
          <div class="counter-item">
            <span class="stat-counter display-xl" data-limit="72" data-suffix="%">0%</span>
            <span class="counter-label">Of customers won't take action until reading a positive review.</span>
          </div>
          <div class="counter-item">
            <span class="stat-counter display-xl" data-limit="54" data-suffix="%">0%</span>
            <span class="counter-label">Increase in business revenue for listings with 40+ positive reviews.</span>
          </div>
          <div class="counter-item">
            <span class="stat-counter display-xl" data-limit="84" data-suffix="%">0%</span>
            <span class="counter-label">Trust online feedback as much as personal recommendations.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Platform Teasers -->
  <section class="section-padding features-teaser-section">
    <div class="section-header">
      <span class="caption">Reputation & Growth Services</span>
      <h2 class="display-lg">Core Growth Systems</h2>
      <p class="body-lg">Scale your local customer acquisition with automated review generation, search engine optimization, and custom high-speed websites.</p>
    </div>

    <div class="card-grid">
      <!-- Service Card 1: Reviews -->
      <div class="card spotlight-card col-4">
        <div class="spotlight-card-content">
          <div class="feature-icon">⭐</div>
          <h3>Google Reviews</h3>
          <p>Automate review invites, write keyword-rich review drafts with AI, escalate negative feedback to owners for resolution, and auto-reply instantly.</p>
          <a href="/reviews" class="learn-more-link" style="margin-top: 20px; display: inline-block; font-weight: 600; color: var(--accent-yellow);">Manage Reviews →</a>
        </div>
      </div>

      <!-- Service Card 2: SEO -->
      <div class="card spotlight-card col-4">
        <div class="spotlight-card-content">
          <div class="feature-icon">📈</div>
          <h3>SEO & Rank Boosting</h3>
          <p>Push your local profile from page twenty to page one. Automate social posts, optimize listings, and implement schema markup.</p>
          <a href="/seo" class="learn-more-link" style="margin-top: 20px; display: inline-block; font-weight: 600; color: var(--accent-yellow);">Boost Rankings →</a>
        </div>
      </div>

      <!-- Service Card 3: Websites -->
      <div class="card spotlight-card col-4">
        <div class="spotlight-card-content">
          <div class="feature-icon">💻</div>
          <h3>Web Design & Performance</h3>
          <p>Get high-speed, custom-coded web structures optimized for high conversion rates, speed compliance, and premium aesthetic layouts.</p>
          <a href="/websites" class="learn-more-link" style="margin-top: 20px; display: inline-block; font-weight: 600; color: var(--accent-yellow);">Explore Websites →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations Showcase Section -->
  <section class="section-padding integrations-section" id="integrations">
    <div class="section-header">
      <span class="caption">Seamless Connections</span>
      <h2 class="display-lg">Sync with 30+ Platforms</h2>
      <p class="body-lg">BrandHyve connects automatically with major review networks, SEO directories, and sales tools to manage feedback and accelerate growth.</p>
    </div>

    <div class="integrations-grid-wrapper">
      <div class="integrations-cloud" id="integrations-cloud">
        <!-- 1. Google -->
        <div class="integration-bubble bubble-lg" style="left: 36%; top: 40%; --brand-color: #4285F4;" data-vx="-0.3" data-vy="-0.8">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114A5.79 5.79 0 0 1 8.2 12.729a5.79 5.79 0 0 1 5.79-5.79c2.519 0 4.39 1.704 5.038 4.114H24C23.15 4.606 18.25 0 12.25 0S1.35 4.606.5 11.13c0 6.523 5.4 12.87 11.75 12.87 6.35 0 11.25-5.285 11.25-11.826 0-.648-.057-1.286-.17-1.89H12.24z"/></svg>
          </span>
        </div>

        <!-- 2. Google Business Profile -->
        <div class="integration-bubble bubble-lg" style="left: 52%; top: 45%; --brand-color: #4285F4;" data-vx="0.2" data-vy="-1.1">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.9 11.8c-.2-1.7-1.6-3-3.3-3.2V5.1c0-1.7-1.4-3.1-3.1-3.1h-7C6.8 2 5.4 3.4 5.4 5.1v3.5c-1.7.2-3.1 1.5-3.3 3.2C2 12 2 12.2 2 12.4c0 3.2 2.6 5.8 5.8 5.8h8.4c3.2 0 5.8-2.6 5.8-5.8 0-.2 0-.4-.1-.6zM7.2 5.1c0-.7.6-1.3 1.3-1.3h7c.7 0 1.3.6 1.3 1.3v3.1H7.2V5.1z"/></svg>
          </span>
        </div>

        <!-- 3. Yelp -->
        <div class="integration-bubble bubble-lg" style="left: 22%; top: 34%; --brand-color: #D32323;" data-vx="-0.9" data-vy="-0.5">
          <span class="integration-icon">★</span>
        </div>

        <!-- 4. Facebook -->
        <div class="integration-bubble bubble-lg" style="left: 68%; top: 36%; --brand-color: #1877F2;" data-vx="-1.2" data-vy="0.3">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </span>
        </div>

        <!-- 5. TripAdvisor -->
        <div class="integration-bubble bubble-md" style="left: 15%; top: 22%; --brand-color: #34E0A1;" data-vx="1.1" data-vy="-0.6">
          <span class="integration-icon">🦉</span>
        </div>

        <!-- 6. Trustpilot -->
        <div class="integration-bubble bubble-lg" style="left: 48%; top: 12%; --brand-color: #00B67A;" data-vx="-0.5" data-vy="-1.3">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          </span>
        </div>

        <!-- 7. Instagram -->
        <div class="integration-bubble bubble-md" style="left: 26%; top: 58%; --brand-color: #E1306C;" data-vx="-1.4" data-vy="-0.2">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </span>
        </div>

        <!-- 8. X / Twitter -->
        <div class="integration-bubble bubble-md" style="left: 70%; top: 56%; --brand-color: #FFFFFF;" data-vx="1.3" data-vy="0.2">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
        </div>

        <!-- 9. TikTok -->
        <div class="integration-bubble bubble-sm" style="left: 12%; top: 72%; --brand-color: #00F2FE;" data-vx="0.8" data-vy="1.1">
          <span class="integration-icon">♪</span>
        </div>

        <!-- 10. LinkedIn -->
        <div class="integration-bubble bubble-md" style="left: 80%; top: 24%; --brand-color: #0077B5;" data-vx="1.4" data-vy="-0.3">
          <span class="integration-icon">in</span>
        </div>

        <!-- 11. Shopify -->
        <div class="integration-bubble bubble-lg" style="left: 48%; top: 72%; --brand-color: #96BF48;" data-vx="0.5" data-vy="-1.2">
          <span class="integration-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </span>
        </div>

        <!-- 12. WooCommerce -->
        <div class="integration-bubble bubble-md" style="left: 32%; top: 78%; --brand-color: #96588A;" data-vx="-0.7" data-vy="1.1">
          <span class="integration-icon">W</span>
        </div>

        <!-- 13. WordPress -->
        <div class="integration-bubble bubble-md" style="left: 32%; top: 16%; --brand-color: #21759B;" data-vx="-1.3" data-vy="-0.7">
          <span class="integration-icon">Wp</span>
        </div>

        <!-- 14. Webflow -->
        <div class="integration-bubble bubble-md" style="left: 64%; top: 16%; --brand-color: #4353FF;" data-vx="1.2" data-vy="0.7">
          <span class="integration-icon">Wf</span>
        </div>

        <!-- 15. Squarespace -->
        <div class="integration-bubble bubble-sm" style="left: 6%; top: 44%; --brand-color: #FFFFFF;" data-vx="-0.2" data-vy="1.3">
          <span class="integration-icon">Sq</span>
        </div>

        <!-- 16. Wix -->
        <div class="integration-bubble bubble-sm" style="left: 90%; top: 48%; --brand-color: #0C80E1;" data-vx="0.9" data-vy="-1.0">
          <span class="integration-icon">Wx</span>
        </div>

        <!-- 17. HubSpot -->
        <div class="integration-bubble bubble-md" style="left: 49%; top: 28%; --brand-color: #FF7A59;" data-vx="-0.4" data-vy="1.2">
          <span class="integration-icon">●</span>
        </div>

        <!-- 18. Salesforce -->
        <div class="integration-bubble bubble-md" style="left: 60%; top: 74%; --brand-color: #00A1E0;" data-vx="1.1" data-vy="-1.1">
          <span class="integration-icon">Sf</span>
        </div>

        <!-- 19. ActiveCampaign -->
        <div class="integration-bubble bubble-sm" style="left: 8%; top: 12%; --brand-color: #356AE6;" data-vx="-1.0" data-vy="-1.1">
          <span class="integration-icon">Ac</span>
        </div>

        <!-- 20. Mailchimp -->
        <div class="integration-bubble bubble-md" style="left: 76%; top: 76%; --brand-color: #FFE01B;" data-vx="1.0" data-vy="1.2">
          <span class="integration-icon">🐒</span>
        </div>

        <!-- 21. Slack -->
        <div class="integration-bubble bubble-md" style="left: 20%; top: 10%; --brand-color: #4A154B;" data-vx="-1.2" data-vy="0.7">
          <span class="integration-icon">#</span>
        </div>

        <!-- 22. Teams -->
        <div class="integration-bubble bubble-sm" style="left: 86%; top: 82%; --brand-color: #4B53BC;" data-vx="1.3" data-vy="-0.8">
          <span class="integration-icon">T</span>
        </div>

        <!-- 23. Zapier -->
        <div class="integration-bubble bubble-md" style="left: 18%; top: 76%; --brand-color: #FF4A00;" data-vx="0.4" data-vy="0.9">
          <span class="integration-icon">*</span>
        </div>

        <!-- 24. Birdeye -->
        <div class="integration-bubble bubble-sm" style="left: 5%; top: 28%; --brand-color: #00A5E3;" data-vx="-0.8" data-vy="-0.9">
          <span class="integration-icon">★</span>
        </div>

        <!-- 25. Podium -->
        <div class="integration-bubble bubble-sm" style="left: 82%; top: 62%; --brand-color: #0062FF;" data-vx="0.7" data-vy="0.8">
          <span class="integration-icon">P</span>
        </div>

        <!-- 26. Yext -->
        <div class="integration-bubble bubble-sm" style="left: 4%; top: 58%; --brand-color: #FF5722;" data-vx="-1.5" data-vy="0.4">
          <span class="integration-icon">Y</span>
        </div>

        <!-- 27. Angi -->
        <div class="integration-bubble bubble-sm" style="left: 92%; top: 30%; --brand-color: #E62A29;" data-vx="0.6" data-vy="-1.3">
          <span class="integration-icon">A</span>
        </div>

        <!-- 28. Houzz -->
        <div class="integration-bubble bubble-sm" style="left: 76%; top: 8%; --brand-color: #7AC142;" data-vx="-0.6" data-vy="1.2">
          <span class="integration-icon">H</span>
        </div>

        <!-- 29. OpenTable -->
        <div class="integration-bubble bubble-sm" style="left: 90%; top: 12%; --brand-color: #DA3743;" data-vx="1.5" data-vy="-0.1">
          <span class="integration-icon">O</span>
        </div>

        <!-- 30. YouTube -->
        <div class="integration-bubble bubble-md" style="left: 88%; top: 66%; --brand-color: #FF0000;" data-vx="-1.1" data-vy="0.8">
          <span class="integration-icon">▶</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Call to Action Banner -->
  <section class="section-padding cta-banner-section">
    <div class="atmosphere-card-grey cta-banner border-beam-card">
      <div class="border-beam-content" style="display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 40px; flex-wrap: wrap;">
        <div class="cta-left">
          <h2 class="display-md">Book your complementary Demo Today!</h2>
          <p class="body-lg" style="margin-top: 10px;">
            See how BrandHyve can automate your review pipeline and scale your local ranking profile in real-time.
          </p>
        </div>
        <div class="cta-right">
          <a href="/contact" class="btn-primary" style="padding: 16px 36px;">Schedule Live Demo</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import '../scripts/main.js';
</script>

<style>
  /* Local Component Styling */
  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 150px;
    position: relative;
    z-index: 10;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: var(--surface-2);
    border: 1px solid var(--hairline);
    padding: 8px 16px;
    border-radius: var(--rounded-pill);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent-yellow);
    margin-bottom: 25px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background-color: var(--accent-yellow);
    border-radius: var(--rounded-full);
    box-shadow: 0 0 10px var(--accent-yellow);
    display: inline-block;
  }

  .highlight-text {
    background: var(--gradient-hive);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subhead {
    max-width: 650px;
    margin: 25px auto 40px;
  }

  .hero-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-bottom: 80px;
  }

  /* Stats indicators details */
  .stats-counters-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    text-align: center;
  }

  @media (max-width: 810px) {
    .stats-counters-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }
  }

  @media (max-width: 480px) {
    .stats-counters-grid {
      grid-template-columns: 1fr;
    }
  }

  .counter-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .counter-item .display-xl {
    color: var(--accent-yellow);
    font-weight: 700;
    margin-bottom: 15px;
  }

  .counter-label {
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-muted);
    max-width: 200px;
  }

  /* Live Dashboard Mockup styles */
  .dashboard-mockup-wrapper {
    width: min(90vw, 1050px);
    position: relative;
  }

  .dashboard-card {
    padding: 0 !important;
    text-align: left;
    box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.8), 0 0 0 1px var(--hairline);
    overflow: hidden;
  }

  .dashboard-header {
    background-color: #0c0c0e;
    border-bottom: 1px solid var(--hairline);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .window-controls {
    display: flex;
    gap: 8px;
  }

  .window-controls .dot {
    width: 12px;
    height: 12px;
    border-radius: var(--rounded-full);
  }

  .window-controls .red { background-color: #ff5f56; }
  .window-controls .yellow { background-color: #ffbd2e; }
  .window-controls .green { background-color: #27c93f; }

  .dashboard-title {
    font-size: 13px;
    color: var(--ink-muted);
    font-family: var(--font-body);
  }

  .dashboard-badge {
    font-size: 11px;
    background-color: rgba(255, 219, 21, 0.1);
    color: var(--accent-yellow);
    border: 1px solid rgba(255, 219, 21, 0.2);
    padding: 2px 8px;
    border-radius: var(--rounded-pill);
  }

  .dashboard-body {
    padding: 30px;
    background-color: var(--surface-1);
  }

  .dashboard-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 30px;
